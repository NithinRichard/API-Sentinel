generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String        @id @default(uuid())
  name             String?
  email            String        @unique
  emailVerified    DateTime?
  image            String?
  hashedPassword   String?
  stripeCustomerId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  accounts         Account[]
  sessions         Session[]
  endpoints        APIEndpoint[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model APIEndpoint {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  endpointUrl  String
  methods      String[]
  apiKey       String      @db.Text
  interval     Int         @default(60)
  alertEmail   String
  alertWebhook String?
  threshold    Int         @default(2000)
  lastChecked  DateTime?
  lastResponse String?     @db.Text
  lastStatus   String      @default("unknown")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  uptimeLogs   UptimeLog[]

  @@index([userId])
  @@index([lastStatus])
  @@index([lastChecked])
}

model UptimeLog {
  id           String      @id @default(uuid())
  endpointId   String
  endpoint     APIEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  isUp         Boolean
  responseTime Int
  status       String
  errorMessage String?     @db.Text
  checkedAt    DateTime    @default(now())

  @@index([endpointId])
  @@index([checkedAt])
  @@index([endpointId, checkedAt])
}
